<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp" android:height="24dp"
    android:viewportWidth="24" android:viewportHeight="24"
    android:tint="?android:attr/textColorSecondary">
    <!-- Mute's bell-with-slash plus a second, crossing slash so the pair reads
         as: mute = one slash, notifications blocked = an X.
         A tinted vector is a single colour, so the crossing slash can't simply
         be drawn on top of the bell — it would disappear into it. Instead the
         bell path carries an extra parallelogram subpath along the second
         diagonal and uses evenOdd fill, which punches a transparent gap
         through the bell there; the stroked line below then sits inside that
         gap and stays visible against the bell. -->
    <path
        android:fillColor="#FF000000"
        android:fillType="evenOdd"
