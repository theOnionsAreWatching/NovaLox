<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true" android:left="6dp" android:right="10dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/focus_fill" />
            <corners android:radius="6dp" />
        </shape>
    </item>
    <item android:state_selected="true" android:left="6dp" android:right="10dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/focus_fill" />
            <corners android:radius="6dp" />
        </shape>
    </item>
    <item android:state_pressed="true" android:left="6dp" android:right="10dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/focus_fill" />
            <corners android:radius="6dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
</selector>
