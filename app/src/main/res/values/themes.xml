<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.DSMS" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="colorAccent">@color/accent_blue</item>
        <item name="android:textColorLink">@color/accent_blue</item>
        <item name="alertDialogTheme">@style/DSMS.AlertDialog</item>
    </style>

    <style name="DSMS.AlertDialog" parent="ThemeOverlay.AppCompat.Dialog.Alert">
        <item name="buttonBarPositiveButtonStyle">@style/DSMS.DialogButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/DSMS.DialogButton</item>
        <item name="buttonBarNeutralButtonStyle">@style/DSMS.DialogButton</item>
        <item name="android:listChoiceBackgroundIndicator">@drawable/bg_focus_pill</item>
    </style>

    <style name="DSMS.DialogButton" parent="Widget.AppCompat.Button.ButtonBar.AlertDialog">
        <item name="android:background">@drawable/bg_focus_pill</item>
        <item name="android:textColor">?attr/colorPrimary</item>
    </style>

    <style name="Accent_Blue" parent="">
        <item name="colorAccent">@color/accent_blue</item>
        <item name="colorPrimary">@color/accent_blue</item>
        <item name="colorControlActivated">@color/accent_blue</item>
    </style>
    <style name="Accent_Teal" parent="">
        <item name="colorAccent">@color/accent_teal</item>
        <item name="colorPrimary">@color/accent_teal</item>
        <item name="colorControlActivated">@color/accent_teal</item>
    </style>
    <style name="Accent_Green" parent="">
        <item name="colorAccent">@color/accent_green</item>
        <item name="colorPrimary">@color/accent_green</item>
        <item name="colorControlActivated">@color/accent_green</item>
    </style>
    <style name="Accent_Orange" parent="">
        <item name="colorAccent">@color/accent_orange</item>
        <item name="colorPrimary">@color/accent_orange</item>
        <item name="colorControlActivated">@color/accent_orange</item>
    </style>
    <style name="Accent_Red" parent="">
        <item name="colorAccent">@color/accent_red</item>
        <item name="colorPrimary">@color/accent_red</item>
        <item name="colorControlActivated">@color/accent_red</item>
    </style>
    <style name="Accent_Purple" parent="">
        <item name="colorAccent">@color/accent_purple</item>
        <item name="colorPrimary">@color/accent_purple</item>
        <item name="colorControlActivated">@color/accent_purple</item>
    </style>
    <style name="Accent_Pink" parent="">
        <item name="colorAccent">@color/accent_pink</item>
        <item name="colorPrimary">@color/accent_pink</item>
        <item name="colorControlActivated">@color/accent_pink</item>
    </style>
    <style name="Accent_Gray" parent="">
        <item name="colorAccent">@color/accent_gray</item>
        <item name="colorPrimary">@color/accent_gray</item>
        <item name="colorControlActivated">@color/accent_gray</item>
    </style>
</resources>
